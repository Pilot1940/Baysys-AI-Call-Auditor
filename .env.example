# Django
SECRET_KEY=change-me-in-prod
DEBUG=True

# Database (Supabase — same instance as Trainer, different schema)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SCHEMA=baysys_call_audit

# Auth backend: "mock" for dev, "crm" for production
AUDIT_AUTH_BACKEND=mock

# Speech analytics provider (currently GreyLabs — keys stay provider-agnostic)
SPEECH_PROVIDER_HOST=https://api.greylabs.ai
SPEECH_PROVIDER_API_KEY=
SPEECH_PROVIDER_API_SECRET=
SPEECH_PROVIDER_TEMPLATE_ID=
SPEECH_PROVIDER_CALLBACK_URL=https://your-domain/audit/webhook/provider/

# Rate limiting (requests per minute to provider)
SPEECH_PROVIDER_RATE_LIMIT=200

# Compliance rules
COMPLIANCE_CALL_WINDOW_START_HOUR=8
COMPLIANCE_CALL_WINDOW_END_HOUR=20
COMPLIANCE_MAX_CALLS_PER_CUSTOMER_PER_DAY=15

# Minimum call duration in seconds to sync (calls shorter than this are excluded)
SYNC_MIN_CALL_DURATION=20

# Minutes after submission before a recording is considered stuck and eligible for polling
POLL_STUCK_AFTER_MINUTES=30

# Comma-separated list of IPs allowed to POST to the provider webhook endpoint.
# Leave empty to allow all sources (default). In production set to your provider's egress IPs.
# Example: SPEECH_PROVIDER_WEBHOOK_ALLOWED_IPS=203.0.113.10,203.0.113.11
SPEECH_PROVIDER_WEBHOOK_ALLOWED_IPS=
